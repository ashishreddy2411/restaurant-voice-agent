# ============================================================
# COPY THIS FILE TO .env AND FILL IN YOUR REAL VALUES
# cp .env.example .env
# The .env file is gitignored and must NEVER be committed.
# ============================================================

# ── LiveKit Cloud ────────────────────────────────────────────
# Where to find: LiveKit Cloud dashboard → your project → Settings
# wss:// URL looks like: wss://your-project-abc123.livekit.cloud
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Deepgram ─────────────────────────────────────────────────
# Where to find: console.deepgram.com → API Keys → Create a new key
# Used for both speech-to-text (STT) and text-to-speech (TTS/Aura)
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Azure OpenAI (via Azure AI Foundry) ──────────────────────
# Where to find: Azure AI Foundry → your project → Deployments → click your model
# ENDPOINT looks like: https://your-resource-name.openai.azure.com/
# DEPLOYMENT is the name you gave your model when deploying (e.g. gpt-5.2-chat)
# API_VERSION: use 2024-08-01-preview or check Azure docs for latest
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat

# ── Supabase ─────────────────────────────────────────────────
# Where to find: supabase.com → your project → Settings → API
# Use the "service_role" key (not the anon key) — it bypasses row-level security
# IMPORTANT: The service_role key is secret — never put it in frontend code
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Agent Configuration ───────────────────────────────────────
# Maximum call length in seconds before the agent politely ends the call.
# Protects against runaway costs. Default: 600 (10 minutes)
MAX_CALL_DURATION_SECONDS=600

# The display name of your restaurant (used in greetings and responses)
RESTAURANT_NAME=The Golden Fork
